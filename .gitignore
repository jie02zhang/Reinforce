# Git 忽略文件

# 操作系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# 编辑器文件
.vscode/
.idea/
*.swp
*.swo
*~
.emacs.desktop

# 日志文件
*.log
/var/log/

# 临时文件
*.tmp
*.temp
/tmp/
/temp/

# 备份文件
*.bak
*.backup
/backup/
/root/backup_*/

# 测试输出
test_output/
*.output
*.result

# Vagrant 文件
.vagrant/
Vagrantfile.local

# 工作流文件（如果是 fork）
.workbuddy/
.codebuddy/

# Python 文件（如果有相关脚本）
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
ENV/

# 系统文件
/proc/
/sys/
/dev/
.run/
